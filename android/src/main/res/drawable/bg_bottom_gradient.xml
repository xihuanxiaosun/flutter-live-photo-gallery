<?xml version="1.0" encoding="utf-8"?>
<!-- 宫格单元格底部渐变遮罩：由透明渐变为半透明黑色，提升徽章文字可读性 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:endColor="#55000000"
        android:startColor="#00000000"
        android:type="linear" />
</shape>
